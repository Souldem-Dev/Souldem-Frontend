# ─────────────────────────────────────────────
# SOULDEM FRONTEND — Environment Variables
# Copy this file to .env and fill in real values
# ─────────────────────────────────────────────

# ── BACKEND API ───────────────────────────────
NEXT_PUBLIC_BACKEND_URL="http://localhost:8000/"

# ── CONTRACTS ─────────────────────────────────
# Must match FACTORY_CONTRACT_ADDRESS in backend .env
NEXT_PUBLIC_BASE_FACTORY_ADDRESS="replace-with-deployed-BaseContract-address"

# ── AUTH ──────────────────────────────────────
# Must be the same value as JWT_SECRET_PHASE in backend .env
JWT_SECRET="replace-with-strong-random-secret-min-32-chars"
